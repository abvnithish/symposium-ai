# --- Provider API keys ---
# OpenAI (GPT)
OPENAI_API_KEY="sk-..."

# Anthropic (Claude)
ANTHROPIC_API_KEY="..."

# Google (Gemini)
GOOGLE_API_KEY="AIza..."
GOOGLE_CLOUD_PROJECT="gen-lang-client-0036675694"
GOOGLE_CLOUD_LOCATION="us-central1"

# --- Optional defaults ---
# Which model acts as the "arbiter" that decides if there's agreement.
# Allowed: gpt | claude | gemini
ARENA_ARBITER_PROVIDER="gpt"

# Models (override per run via CLI flags)
 OPENAI_MODEL="gpt-5.3-mini"
 ANTHROPIC_MODEL="claude-4-5-sonnet-latest"
 GEMINI_MODEL="gemini-3-flash-preview"
